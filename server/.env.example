# Telegram bot token from @BotFather. Leave empty to enable dev mode
# (browser testing with ?dev=1&id=12345 instead of real Telegram initData).
TELEGRAM_BOT_TOKEN=

# Set ALLOW_DEV_AUTH=1 to keep accepting ?dev=1&id=… even when a real token
# is configured. Useful for testing in a browser while the bot is already set
# up. Leave unset (or =0) in production.
ALLOW_DEV_AUTH=

# Secret used to sign session JWTs. Use any long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Server port.
PORT=3001

# Comma-separated origins allowed for CORS (Vite dev server, tunnel URL, etc.)
CORS_ORIGINS=http://localhost:5173
